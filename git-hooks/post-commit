#!/bin/sh
set -eu

ROOT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd)"

if command -v powershell.exe >/dev/null 2>&1; then
  powershell.exe -NoProfile -ExecutionPolicy Bypass -File "$ROOT_DIR/scripts/restart-dev-server.ps1" || exit 1
elif command -v pwsh >/dev/null 2>&1; then
  pwsh -NoProfile -ExecutionPolicy Bypass -File "$ROOT_DIR/scripts/restart-dev-server.ps1" || exit 1
else
  echo "[hook] PowerShell not found; cannot restart dev server" >&2
  exit 1
fi