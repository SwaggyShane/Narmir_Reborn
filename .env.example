# ==========================================
# NARMIR REBORN - ENVIRONMENT TEMPLATE
# ==========================================
# Copy this file to .env and fill in values
# DO NOT commit .env to Git
# .env is in .gitignore for security

# ==========================================
# DEVELOPMENT SETUP
# ==========================================
# For local development, use short/simple values
# For production (Railway), use strong random values (see RAILWAY_SECRETS.md)

# Server Mode
# development = dev server, CORS '*', no view caching
# production = production server, strict CORS, caching enabled
NODE_ENV="development"

# ==========================================
# CRITICAL SECRETS (Server won't start without these)
# ==========================================

# JWT Secret for signing authentication tokens
# Dev: Can be short, but must be present
# Prod: Must be 32+ characters, strong random (see RAILWAY_SECRETS.md)
JWT_SECRET="test-jwt-secret-min-32-characters-long"

# PostgreSQL Database Connection
# Dev: Use local database (docker or installed postgres)
# Prod: Will be auto-generated by Railway (see RAILWAY_SECRETS.md)
DATABASE_URL="postgresql://postgres:smoke@localhost/narmir_smoke"

# ==========================================
# PRODUCTION REQUIRED
# ==========================================

# Frontend domain for CORS
# Dev: http://localhost:5173 (Vite dev server)
# Prod: https://narmirreborn.com (production domain)
CORS_ORIGIN="http://localhost:5173"

# ==========================================
# OPTIONAL SECRETS
# ==========================================

# Admin endpoint secret
# Leave blank to skip admin endpoints in dev
# Prod: Set to 16+ character random value (see RAILWAY_SECRETS.md)
ADMIN_SECRET="test-admin-secret"

# Email confirmation token secret
# Leave blank for development
# Prod: Set to 16+ character random value (see RAILWAY_SECRETS.md)
CONFIRM_SECRET="test-confirm-secret"

# ==========================================
# DISCORD INTEGRATION (Optional)
# ==========================================
# Only configure if using Discord bot for updates/notifications

# Discord Bot Token (get from https://discord.com/developers/applications)
DISCORD_BOT_TOKEN=""

# Discord channel for update announcements
DISCORD_UPDATES_CHANNEL_ID=""

# Discord channel for bug reports
DISCORD_BUG_REPORTS_CHANNEL_ID=""

# ==========================================
# ADMIN SECURITY (Optional)
# ==========================================

# IP whitelist for admin endpoints (comma-separated)
# If set, only these IPs can access admin routes
# Leave empty to allow any IP (not recommended for production)
ADMIN_ALLOWED_IPS=""

# ==========================================
# COMBAT & ELEVATION SYSTEM (Optional)
# ==========================================

# Combat: V2 only (combat-resolver via combat-wrappers). Legacy aggregate combat
# and USE_COMBAT_V2 opt-out were removed 2026-07-16; the env var is ignored.

# Elevation system Phase 3 flags. Default true as of 2026-07-15 (elevation
# generation is wired into world boot — see game/world-elevation.js). Set
# any of these to "false" to disable individually.
# FEATURE_ELEVATION_COMBAT="false"
# FEATURE_ELEVATION_MOVEMENT="false"
# FEATURE_ELEVATION_SPELLS="false"

# ==========================================
# NOTES FOR DEVELOPERS
# ==========================================

# 1. Create .env file in project root
#    cp .env.example .env

# 2. For local development, values above are sufficient

# 3. For production deployment to Railway:
#    - DO NOT commit .env with production secrets
#    - All secrets go in Railway Variables tab
#    - See RAILWAY_SECRETS.md for detailed setup
#    - See DEPLOYMENT_CHECKLIST.md for deployment guide

# 4. Never share .env file or secrets in chat/email
#    If compromised:
#    - Rotate all secrets immediately
#    - Redeploy to production
#    - Check logs for unauthorized access

# 5. Password strength requirements:
#    - JWT_SECRET: 32+ characters, cryptographically random
#    - ADMIN_SECRET: 16+ characters
#    - CONFIRM_SECRET: 16+ characters
#    Generate strong secrets: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

# 6. PostgreSQL Connection String Format:
#    postgresql://[user]:[password]@[host]:[port]/[database]
#
#    Examples:
#    - Local: postgresql://postgres:smoke@localhost/narmir_smoke
#    - Railway: postgresql://postgres:xxxxx@xxxxx.railway.internal:5432/railway
#    - Remote: postgresql://user:pass@db.example.com:5432/narmir_prod

# ==========================================
# LOCAL DEVELOPMENT DATABASE SETUP
# ==========================================
# If using Docker:
#   docker run --name postgres -e POSTGRES_PASSWORD=smoke -p 5432:5432 postgres:15
#   docker exec postgres psql -U postgres -c "CREATE DATABASE narmir_smoke;"

# If using system postgres:
#   sudo -u postgres createdb narmir_smoke
#   sudo -u postgres psql -c "ALTER USER postgres PASSWORD 'smoke';"

# Test connection:
#   psql postgresql://postgres:smoke@localhost/narmir_smoke
#   (Type \q to exit)
