# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# DATABASE_URL: Required. PostgreSQL database connection string.
# The application uses PostgreSQL as its sole database engine.
DATABASE_URL="postgresql://username:password@host:port/database"

# DISCORD_BOT_TOKEN: Required for Discord bot functionality.
# Get from Discord Developer Portal: https://discord.com/developers/applications
# Instructions: Create app → Bot tab → Copy token
DISCORD_BOT_TOKEN="YOUR_DISCORD_BOT_TOKEN_HERE"

# DISCORD_UPDATES_CHANNEL_ID: Channel ID for posting updates (optional).
# If not set, bot will look for #updates channel by name.
# Get channel ID: Right-click channel → Copy Channel ID (enable Developer Mode in Discord)
DISCORD_UPDATES_CHANNEL_ID="YOUR_CHANNEL_ID_HERE"
