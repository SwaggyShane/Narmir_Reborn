# ==========================================
# NARMIR REBORN - ENVIRONMENT VARIABLES
# ==========================================

# JWT_SECRET: Required. Secret key for signing JWT authentication tokens.
# CRITICAL: Must be set before server starts. Server will crash if missing.
# Should be a strong random string (minimum 32 characters recommended).
JWT_SECRET="your-super-secret-jwt-key-min-32-chars"

# DATABASE_URL: Required. PostgreSQL database connection string.
# Format: postgresql://username:password@host:port/database
# Example: postgresql://user:pass@localhost:5432/narmir
DATABASE_URL="postgresql://username:password@host:port/database"

# NODE_ENV: Deployment environment. Set to "production" for Railway, "development" for local.
# Controls logging, error messages, CORS behavior, and feature availability.
NODE_ENV="production"

# CORS_ORIGIN: Required in production. URL of the frontend client.
# Controls which origins are allowed to make cross-origin requests.
# Example: https://narmirreborn.com
# In development (NODE_ENV !== production), CORS is automatically set to '*'
CORS_ORIGIN="https://your-frontend-url.com"

# ADMIN_SECRET: Secret key for admin authentication endpoints.
# Used to verify admin requests. Should be a strong random string.
ADMIN_SECRET="your-admin-secret-key"

# CONFIRM_SECRET: Secret key for email confirmation or verification tokens.
# Used for account verification flows. Should be a strong random string.
CONFIRM_SECRET="your-confirm-secret-key"

# DISCORD_BOT_TOKEN: Same bot for chat sync, server-side pushes, and !update commands.
# Set on both web and discord-bot Railway services for instant push on bug/changelog events.
# Get from Discord Developer Portal → Bot tab → Copy token
DISCORD_BOT_TOKEN="YOUR_DISCORD_BOT_TOKEN_HERE"

# DISCORD_UPDATES_CHANNEL_ID: Changelog publishes (admin Evolution tab) → #updates
DISCORD_UPDATES_CHANNEL_ID="YOUR_UPDATES_CHANNEL_ID_HERE"

# DISCORD_BUG_REPORTS_CHANNEL_ID: In-game bug reports → #bug-reports
DISCORD_BUG_REPORTS_CHANNEL_ID="YOUR_BUG_REPORTS_CHANNEL_ID_HERE"

# Optional webhooks (instant post without bot token on web service):
DISCORD_UPDATES_WEBHOOK_URL=""
DISCORD_BUG_REPORTS_WEBHOOK_URL=""
